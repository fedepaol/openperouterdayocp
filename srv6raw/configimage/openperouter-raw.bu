variant: openshift
version: 4.20.0
metadata:
  name: 99-master-openperouter
  labels:
    machineconfiguration.openshift.io/role: master
storage:
  files:
    # --- Rawconfig scripts (mode 0755) ---
    - path: /usr/local/bin/openperouter-common.sh
      mode: 0755
      overwrite: true
      contents:
        local: rawconfig/openperouter-common.sh
    - path: /usr/local/bin/setup-underlay.sh
      mode: 0755
      overwrite: true
      contents:
        local: rawconfig/setup-underlay.sh
    - path: /usr/local/bin/setup-network.sh
      mode: 0755
      overwrite: true
      contents:
        local: rawconfig/setup-network.sh
    - path: /usr/local/bin/generate-config.sh
      mode: 0755
      overwrite: true
      contents:
        local: rawconfig/generate-config.sh
    - path: /usr/local/bin/bridge-refresher.sh
      mode: 0755
      overwrite: true
      contents:
        local: rawconfig/bridge-refresher.sh
    - path: /usr/local/bin/can_start.sh
      mode: 0755
      overwrite: true
      contents:
        local: quadlets/can_start.sh
    - path: /var/lib/openperouter/can_start.sh
      mode: 0755
      overwrite: true
      contents:
        local: quadlets/can_start.sh
    # --- Empty openpe_config.yaml (controller needs it to exist) ---
    - path: /var/lib/openperouter/configs/openpe_config.yaml
      mode: 0644
      overwrite: true
      contents:
        inline: ""
    # --- Rawconfig templates and env (mode 0644) ---
    - path: /etc/openperouter/templates/openpe_evpn.yaml.template
      mode: 0644
      overwrite: true
      contents:
        local: rawconfig/openpe_evpn.yaml.template
    - path: /etc/openperouter/templates/openpe_evpn.yaml_rr.template
      mode: 0644
      overwrite: true
      contents:
        local: rawconfig/openpe_evpn.yaml_rr.template
    - path: /etc/openperouter/vpn-setup.env
      mode: 0644
      overwrite: true
      contents:
        local: rawconfig/vpn-setup.env
    # --- FRR daemons file (enables isisd for ISIS + SRv6) ---
    - path: /etc/perouter/daemons
      mode: 0644
      overwrite: true
      contents:
        local: quadlets/daemons
    # --- Node index script ---
    - path: /usr/local/bin/openperouter-node-index.sh
      mode: 0755
      overwrite: true
      contents:
        local: common/openperouter-node-index.sh
    # --- Shared installer patching script ---
    - path: /usr/local/bin/patch-installer-config.sh
      mode: 0755
      overwrite: true
      contents:
        local: common/patch-installer-config.sh
    # --- Quadlet files ---
    - path: /etc/containers/systemd/controllerpod.pod
      mode: 0644
      overwrite: true
      contents:
        local: quadlets/controllerpod.pod
    - path: /etc/containers/systemd/controller.container
      mode: 0644
      overwrite: true
      contents:
        local: quadlets/controller.container
    - path: /etc/containers/systemd/routerpod.pod
      mode: 0644
      overwrite: true
      contents:
        local: quadlets/routerpod.pod
    - path: /etc/containers/systemd/frr.container
      mode: 0644
      overwrite: true
      contents:
        local: quadlets/frr.container
    - path: /etc/containers/systemd/reloader.container
      mode: 0644
      overwrite: true
      contents:
        local: quadlets/reloader.container
    - path: /etc/containers/systemd/frr-sockets.volume
      mode: 0644
      overwrite: true
      contents:
        local: quadlets/frr-sockets.volume
systemd:
  units:
    # --- Quadlet services ---
    - name: controllerpod.service
      enabled: true
    - name: controller.service
      enabled: true
    - name: routerpod.service
      enabled: true
    - name: frr.service
      enabled: true
    - name: reloader.service
      enabled: true
    - name: frr-sockets.service
      enabled: true
    # --- Rawconfig systemd services ---
    - name: setup-underlay.service
      enabled: true
      contents: |
        [Unit]
        Description=OpenPERouter Underlay Setup
        Documentation=https://github.com/openperouter/openperouter
        After=network-online.target routerpod-pod.service frr.service
        Requires=routerpod-pod.service
        Wants=network-online.target

        [Service]
        Type=oneshot
        RemainAfterExit=yes
        User=root
        Group=root
        EnvironmentFile=-/etc/openperouter/vpn-setup.env
        ExecStartPre=/usr/local/bin/can_start.sh
        ExecStart=/usr/local/bin/setup-underlay.sh
        StandardOutput=journal
        StandardError=journal
        SyslogIdentifier=setup-underlay
        TimeoutStartSec=480
        TimeoutStopSec=10

        [Install]
        WantedBy=multi-user.target
    - name: setup-network.service
      enabled: true
      contents: |
        [Unit]
        Description=OpenPERouter Network Infrastructure Setup
        Documentation=https://github.com/openperouter/openperouter
        After=setup-underlay.service
        Requires=setup-underlay.service

        [Service]
        Type=oneshot
        RemainAfterExit=yes
        User=root
        Group=root
        EnvironmentFile=-/etc/openperouter/vpn-setup.env
        ExecStart=/usr/local/bin/setup-network.sh
        StandardOutput=journal
        StandardError=journal
        SyslogIdentifier=setup-network
        TimeoutStartSec=120
        TimeoutStopSec=10

        [Install]
        WantedBy=multi-user.target
    - name: generate-config.service
      enabled: true
      contents: |
        [Unit]
        Description=OpenPERouter Configuration Generator
        Documentation=https://github.com/openperouter/openperouter
        # Must run after setup-network to avoid kernel NULL deref in vrf_ifindex_lookup_by_table_id
        # when zebra installs SRv6 End.DT routes before the VRF exists (kernel 5.14, RHCOS 9.6)
        After=setup-network.service
        Requires=setup-network.service

        [Service]
        Type=oneshot
        RemainAfterExit=yes
        User=root
        Group=root
        EnvironmentFile=-/etc/openperouter/vpn-setup.env
        ExecStart=/usr/local/bin/generate-config.sh
        StandardOutput=journal
        StandardError=journal
        SyslogIdentifier=generate-config
        TimeoutStartSec=60
        TimeoutStopSec=10

        [Install]
        WantedBy=multi-user.target
    # --- Bridge refresher (mimics OpenPERouter bridge refresher) ---
    - name: bridge-refresher.service
      enabled: true
      contents: |
        [Unit]
        Description=OpenPERouter Bridge Refresher
        Documentation=https://github.com/openperouter/openperouter
        After=setup-network.service generate-config.service
        Requires=setup-network.service

        [Service]
        Type=simple
        User=root
        Group=root
        EnvironmentFile=-/etc/openperouter/vpn-setup.env
        ExecStart=/usr/local/bin/bridge-refresher.sh
        Restart=always
        RestartSec=5
        StandardOutput=journal
        StandardError=journal
        SyslogIdentifier=bridge-refresher

        [Install]
        WantedBy=multi-user.target
    # --- Node index service ---
    - name: openperouter-node-index.service
      enabled: true
      contents: |
        [Unit]
        Description=Set OpenPERouter nodeIndex from bridge IP
        After=network-online.target
        Before=controllerpod.service routerpod.service
        Wants=network-online.target

        [Service]
        Type=oneshot
        ExecStart=/usr/local/bin/openperouter-node-index.sh
        RemainAfterExit=yes

        [Install]
        WantedBy=multi-user.target
    # --- Shared installer patching service ---
    - name: enable-virtual-interfaces.service
      enabled: true
      contents: |
        [Unit]
        Description=Patch Assisted Service installer config for openperouter
        Before=assisted-service-pod.service

        [Service]
        Type=oneshot
        ExecStart=/usr/local/bin/patch-installer-config.sh
        Restart=on-failure
        RestartSec=2
        RemainAfterExit=yes

        [Install]
        WantedBy=assisted-service-pod.service
