# OpenPERouter VPN Setup Environment Variables
# Defaults tuned for the dev-scripts environment (ISIS + SRv6 mode)
#
# Location on node: /etc/openperouter/vpn-setup.env

# ============================================================================
# Underlay Configuration (setup-underlay.service)
# ============================================================================

# Physical NIC to move into FRR namespace for ISIS adjacency
UNDERLAY_NIC=enp2s0

# Timeout (in seconds) to wait for FRR container to become ready
FRR_READY_TIMEOUT=60

# Timeout (in seconds) to wait for br0/br-ex to acquire an IP address
BR0_READY_TIMEOUT=120

# ============================================================================
# BGP Configuration (generate-config.service)
# ============================================================================

# iBGP AS number (all nodes share the same AS)
BGP_AS=65500

# Node index of the EVPN/VPN route reflector (br0 last octet)
# The node whose br0 last octet matches this becomes the RR
RR_NODE_IDX=2

# IPv6 loopback of the TOR (external FRR) — all nodes peer with this
# for SRv6 VPN routes (ipv4/ipv6 vpn); RR reflects only l2vpn evpn
TOR_LOOPBACK=fc00:0:20::1

# IPv6 prefix for dynamic EVPN client peers (bgp listen range on RR)
EVPN_LISTEN_RANGE=fc00::/16

# ============================================================================
# ISIS / SRv6 Configuration
# ============================================================================

# ISIS area prefix (nodes derive their NET from this + node index)
ISIS_AREA=49.0001

# ============================================================================
# VPN Configuration (generate-config.service / setup-network.service)
# ============================================================================

# VRF name
VRF_NAME=red

# VRF routing table ID
VRF_TABLE=1100

# L2VPN VXLAN Network Identifier (VNI) — L2 overlay still uses VXLAN
L2_VNI=210

# VXLAN UDP destination port
VXLAN_PORT=4789

# Interface to bind VTEP IP on in FRR namespace
VTEP_INTERFACE=lo

# L2VPN gateway IP address (CIDR notation)
L2_GATEWAY_IP=192.168.110.1/24
L2_GATEWAY_IP_V6=fd00:110::1/64
