apiVersion: v1
baseDomain: example.com
compute:
- hyperthreading: Enabled
  name: worker
  replicas: 2
  architecture: null
controlPlane:
  architecture: null
  hyperthreading: Enabled
  name: master
  replicas: 3
fips: false
metadata:
  name: sno-lab
  namespace: cluster0
networking:
  clusterNetwork:
  - cidr: 10.128.0.0/14
    hostPrefix: 23
  machineNetwork:
  - cidr: 192.168.110.0/24
  serviceNetwork:
  - 172.30.0.0/16
  networkType: OVNKubernetes
platform:
  baremetal:
    apiVIPs:
    - 192.168.110.10
    ingressVIPs:
    - 192.168.110.11
pullSecret: PULL_SECRET_PLACEHOLDER
sshKey: ssh-rsa 
  fpaoline@cnfdr7.telco5g.eng.rdu2.redhat.com
